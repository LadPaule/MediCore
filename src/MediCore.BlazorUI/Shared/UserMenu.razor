<AuthorizeView>
    <Authorized Context="authContext">
        <div class="dropdown">
            <button class="btn btn-outline-light dropdown-toggle" style="color: #285A48" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle" style="color: #285A48"></i>
                @authContext.User.Identity?.Name
            </button>

            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <span class="dropdown-item-text text-muted small">
                        @authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                    </span>
                </li>
                <li>
                    <hr class="dropdown-divider">
                </li>
                <li>
                    <a class="dropdown-item text-danger" href="/logout">
                        <i class="bi bi-box-arrow-right"></i>
                        Logout
                    </a>
                </li>
            </ul>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="btn btn-outline-light" href="/login" style="color: #285A48">
            <i class="bi bi-box-arrow-in-right"></i>
            Login
        </a>
    </NotAuthorized>
</AuthorizeView>
