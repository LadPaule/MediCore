@page "/patients"
@attribute [Authorize]
@inject PatientService PatientService
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthState

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-0">@(scopedToDoctor ? "My Patients" : "Patients")</h3>
        @if (scopedToDoctor)
        {
            <small class="text-muted">Patients assigned to you.</small>
        }
    </div>
    <AuthorizeView Roles="Admin,Receptionist">
        <Authorized>
            <a href="/patients/create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Add Patient
            </a>
        </Authorized>
    </AuthorizeView>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading patients...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadPatients">Retry</button>
    </div>
}
else if (patients == null || patients.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-people" style="font-size: 3rem; color: #ccc;"></i>
        <p class="text-muted mt-2">
            @(scopedToDoctor
                ? "No patients are assigned to you yet."
                : "No patients found. Add your first patient to get started.")
        </p>
    </div>
}
else
{
    <input class="form-control mb-3" placeholder="Search patients..."
           value="@searchText"
           @oninput="OnSearchInput" />

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Email</th>
                @if (!scopedToDoctor)
                {
                    <th>Assigned Doctor</th>
                }
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in FilteredPatients)
            {
                <tr>
                    <td>@p.FirstName @p.LastName</td>
                    <td>@p.PhoneNumber</td>
                    <td>@p.Email</td>
                    @if (!scopedToDoctor)
                    {
                        <td>
                            @if (string.IsNullOrEmpty(p.AssignedDoctorName))
                            {
                                <span class="badge bg-secondary">Unassigned</span>
                            }
                            else
                            {
                                @p.AssignedDoctorName
                            }
                        </td>
                    }
                    <td>
                        <a href="patients/@p.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye"></i> View
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<Patient>? patients;
    string searchText = "";
    bool isLoading = true;
    bool scopedToDoctor;
    string? errorMessage;

    IEnumerable<Patient> FilteredPatients =>
        (patients ?? new()).Where(p =>
            string.IsNullOrWhiteSpace(searchText) ||
            $"{p.FirstName} {p.LastName}".Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            (p.PhoneNumber?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (p.Email?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));

    void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
    }

    async Task LoadPatients()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            await AuthService.InitializeAsync();

            var auth = await AuthState.GetAuthenticationStateAsync();
            var user = auth.User;
            var isDoctor = user.IsInRole("Doctor");
            var isAdmin = user.IsInRole("Admin");
            scopedToDoctor = isDoctor && !isAdmin;

            patients = scopedToDoctor
                ? await PatientService.GetMyPatients()
                : await PatientService.GetPatients();
        }
        catch
        {
            errorMessage = "Failed to load patients.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
