@page "/pharmacy/medicines"
@attribute [Authorize]
@inject PharmacyService PharmacyService

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="m-0">Medicine Inventory</h3>
    <a href="/pharmacy/medicines/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Medicine
    </a>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading medicines...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadMedicines">Retry</button>
    </div>
}
else
{
    <input class="form-control mb-3"
           placeholder="Search medicine..."
           value="@searchText"
           @oninput="OnSearchInput" />

    @if (!FilteredMedicines.Any())
    {
        <p class="text-muted text-center py-3">No medicines found.</p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Stock</th>
                    <th>Price</th>
                    <th>Expiry</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in FilteredMedicines)
                {
                    <tr>
                        <td>@m.Name</td>
                        <td>
                            <span class="badge @(m.StockQuantity < 10 ? "bg-danger" : "bg-success")">
                                @m.StockQuantity
                            </span>
                        </td>
                        <td>@m.Price.ToString("C")</td>
                        <td>@m.ExpiryDate.ToShortDateString()</td>
                        <td>
                            <a class="btn btn-sm btn-primary me-1" href="@($"/pharmacy/medicines/{m.Id}")">
                                <i class="bi bi-gear"></i> Manage
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteMedicine(m.Id)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (actionMessage != null)
    {
        <div class="alert alert-info mt-2">@actionMessage</div>
    }
}

@code {
    List<MedicineVM> medicines = new();
    string searchText = "";
    bool isLoading = true;
    string? errorMessage;
    string? actionMessage;

    IEnumerable<MedicineVM> FilteredMedicines =>
        medicines.Where(m =>
            string.IsNullOrWhiteSpace(searchText) ||
            (m.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));

    void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadMedicines();
    }

    async Task LoadMedicines()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            medicines = await PharmacyService.GetMedicinesAsync();
        }
        catch
        {
            errorMessage = "Failed to load medicines.";
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task DeleteMedicine(Guid id)
    {
        var success = await PharmacyService.DeleteMedicineAsync(id);
        if (success)
        {
            medicines.RemoveAll(x => x.Id == id);
            actionMessage = "Medicine deleted.";
        }
        else
        {
            actionMessage = "Failed to delete medicine.";
        }
        StateHasChanged();
        await Task.Delay(2000);
        actionMessage = null;
        StateHasChanged();
    }
}
