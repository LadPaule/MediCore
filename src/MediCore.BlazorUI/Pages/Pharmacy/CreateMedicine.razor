@page "/pharmacy/medicines/create"
@attribute [Authorize(Roles = "Admin,Pharmacist")]
@inject PharmacyService PharmacyService
@inject NavigationManager Navigation

<h3 class="mb-4">Add Medicine to Inventory</h3>

<div class="card" style="max-width: 700px;">
    <div class="card-body">
        <EditForm Model="medicine" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText @bind-Value="medicine.Name" class="form-control" placeholder="e.g. Paracetamol 500mg" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Stock Quantity</label>
                    <InputNumber @bind-Value="medicine.StockQuantity" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Reorder Level</label>
                    <InputNumber @bind-Value="medicine.ReorderLevel" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Price</label>
                    <InputNumber @bind-Value="medicine.Price" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Expiry Date</label>
                    <InputDate @bind-Value="medicine.ExpiryDate" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Manufacturer</label>
                <InputText @bind-Value="medicine.Manufacturer" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea @bind-Value="medicine.Description" class="form-control" rows="3" />
            </div>

            @if (message != null)
            {
                <div class="alert @(isSuccess ? "alert-success" : "alert-danger") mb-3">@message</div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save Medicine")
                </button>
                <a href="/pharmacy/medicines" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    CreateMedicineVM medicine = new();
    bool isSaving;
    string? message;
    bool isSuccess;

    async Task Save()
    {
        isSaving = true;
        message = null;
        try
        {
            var ok = await PharmacyService.CreateMedicineAsync(medicine);
            if (ok)
            {
                isSuccess = true;
                message = "Medicine added to inventory.";
                await Task.Delay(800);
                Navigation.NavigateTo("/pharmacy/medicines");
            }
            else
            {
                isSuccess = false;
                message = "Failed to add medicine.";
            }
        }
        catch
        {
            isSuccess = false;
            message = "Failed to add medicine.";
        }
        finally
        {
            isSaving = false;
        }
    }
}
