@page "/pharmacy/medicines/{Id:guid}"
@attribute [Authorize(Roles = "Admin,Pharmacist")]
@inject PharmacyService PharmacyService
@inject NavigationManager Navigation

@if (medicine == null && !notFound)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (notFound)
{
    <div class="alert alert-warning">Medicine not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="m-0">@medicine!.Name</h3>
            <small class="text-muted">@medicine.Manufacturer</small>
        </div>
        <a href="/pharmacy/medicines" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    @if (banner != null)
    {
        <div class="alert @(bannerSuccess ? "alert-success" : "alert-danger")">@banner</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card p-3 text-center shadow-sm">
                <small class="text-muted">In Stock</small>
                <h2 class="m-0 @(medicine.StockQuantity <= medicine.ReorderLevel ? "text-warning" : "text-success")">
                    @medicine.StockQuantity
                </h2>
                <small class="text-muted">Reorder at @medicine.ReorderLevel</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 text-center shadow-sm">
                <small class="text-muted">Unit Price</small>
                <h2 class="m-0">@medicine.Price.ToString("C")</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 text-center shadow-sm">
                <small class="text-muted">Expiry</small>
                <h4 class="m-0 @(medicine.ExpiryDate.Date <= DateTime.UtcNow.Date.AddDays(30) ? "text-danger" : "")">
                    @medicine.ExpiryDate.ToShortDateString()
                </h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 text-center shadow-sm">
                <small class="text-muted">Stock Value</small>
                <h4 class="m-0">@((medicine.StockQuantity * medicine.Price).ToString("C"))</h4>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "restock" ? "active" : "")" @onclick='() => activeTab = "restock"'>
                <i class="bi bi-box-arrow-in-down me-1"></i> Restock
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "adjust" ? "active" : "")" @onclick='() => activeTab = "adjust"'>
                <i class="bi bi-clipboard-check me-1"></i> Adjust Stock
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "edit" ? "active" : "")" @onclick='() => activeTab = "edit"'>
                <i class="bi bi-pencil me-1"></i> Edit Details
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "history" ? "active" : "")" @onclick='() => activeTab = "history"'>
                <i class="bi bi-clock-history me-1"></i> History
            </button>
        </li>
    </ul>

    @if (activeTab == "restock")
    {
        <div class="card">
            <div class="card-body" style="max-width: 500px;">
                <p class="text-muted">New shipment arrived? Add to current stock.</p>
                <div class="mb-3">
                    <label class="form-label">Quantity Received</label>
                    <input type="number" min="1" class="form-control" @bind="restockForm.Quantity" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Note (optional)</label>
                    <input class="form-control" @bind="restockForm.Note" placeholder="e.g. PO #1234" />
                </div>
                <button class="btn btn-success" @onclick="DoRestock" disabled="@busy">
                    @(busy ? "Saving..." : $"Add {restockForm.Quantity} units")
                </button>
            </div>
        </div>
    }
    else if (activeTab == "adjust")
    {
        <div class="card">
            <div class="card-body" style="max-width: 500px;">
                <p class="text-muted">Set stock to a specific number (e.g. after physical count, damage, expiry write-off).</p>
                <div class="mb-3">
                    <label class="form-label">New Stock Quantity</label>
                    <input type="number" min="0" class="form-control" @bind="adjustForm.NewQuantity" />
                    <small class="text-muted">Current: @medicine.StockQuantity</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Reason</label>
                    <input class="form-control" @bind="adjustForm.Reason" placeholder="e.g. Physical count, Damaged, Expired" />
                </div>
                <button class="btn btn-warning" @onclick="DoAdjust" disabled="@busy">
                    @(busy ? "Saving..." : "Set new quantity")
                </button>
            </div>
        </div>
    }
    else if (activeTab == "edit")
    {
        <div class="card">
            <div class="card-body" style="max-width: 700px;">
                <p class="text-muted">Edit medicine details. To change stock, use Restock or Adjust.</p>
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="editForm.Name" />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Price</label>
                        <input type="number" step="0.01" class="form-control" @bind="editForm.Price" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Reorder Level</label>
                        <input type="number" min="0" class="form-control" @bind="editForm.ReorderLevel" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Expiry Date</label>
                    <input type="date" class="form-control" @bind="editForm.ExpiryDate" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Manufacturer</label>
                    <input class="form-control" @bind="editForm.Manufacturer" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="3" @bind="editForm.Description"></textarea>
                </div>
                <button class="btn btn-primary" @onclick="DoUpdate" disabled="@busy">
                    @(busy ? "Saving..." : "Save changes")
                </button>
            </div>
        </div>
    }
    else if (activeTab == "history")
    {
        <div class="card">
            <div class="card-body">
                @if (!medicine.RecentTransactions.Any())
                {
                    <p class="text-muted">No transactions recorded yet.</p>
                }
                else
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th class="text-end">Change</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in medicine.RecentTransactions)
                            {
                                <tr>
                                    <td>@t.CreatedAt.ToLocalTime().ToString("g")</td>
                                    <td>@t.TransactionType</td>
                                    <td class="text-end @(t.QuantityChanged >= 0 ? "text-success" : "text-danger")">
                                        @(t.QuantityChanged >= 0 ? "+" : "")@t.QuantityChanged
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    MedicineDetailVM? medicine;
    bool notFound;
    bool busy;
    string activeTab = "restock";
    string? banner;
    bool bannerSuccess;

    RestockVM restockForm = new();
    AdjustStockVM adjustForm = new();
    UpdateMedicineVM editForm = new();

    protected override async Task OnInitializedAsync() => await Load();

    async Task Load()
    {
        medicine = await PharmacyService.GetMedicineAsync(Id);
        if (medicine == null) { notFound = true; return; }

        adjustForm.NewQuantity = medicine.StockQuantity;
        editForm = new UpdateMedicineVM
        {
            Name = medicine.Name,
            ReorderLevel = medicine.ReorderLevel,
            Price = medicine.Price,
            ExpiryDate = medicine.ExpiryDate,
            Description = medicine.Description,
            Manufacturer = medicine.Manufacturer
        };
    }

    async Task DoRestock()
    {
        if (restockForm.Quantity < 1) { Banner("Enter a quantity of at least 1.", false); return; }
        busy = true;
        var (ok, err) = await PharmacyService.RestockAsync(Id, restockForm);
        busy = false;
        if (ok)
        {
            Banner($"Added {restockForm.Quantity} units.", true);
            restockForm = new();
            await Load();
        }
        else Banner(err ?? "Failed to restock.", false);
    }

    async Task DoAdjust()
    {
        if (string.IsNullOrWhiteSpace(adjustForm.Reason)) { Banner("Reason is required.", false); return; }
        busy = true;
        var (ok, err) = await PharmacyService.AdjustStockAsync(Id, adjustForm);
        busy = false;
        if (ok)
        {
            Banner("Stock adjusted.", true);
            await Load();
        }
        else Banner(err ?? "Failed to adjust.", false);
    }

    async Task DoUpdate()
    {
        busy = true;
        var (ok, err) = await PharmacyService.UpdateMedicineAsync(Id, editForm);
        busy = false;
        if (ok)
        {
            Banner("Details updated.", true);
            await Load();
        }
        else Banner(err ?? "Failed to update.", false);
    }

    void Banner(string text, bool success)
    {
        banner = text;
        bannerSuccess = success;
    }
}
