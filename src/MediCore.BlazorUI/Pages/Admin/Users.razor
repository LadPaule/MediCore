@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using MediCore.BlazorUI.Models.Admin
@inject HttpClient Http

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">User Management</h2>
    <button class="btn btn-primary" @onclick="OpenCreateModal">
        <i class="bi bi-plus-circle me-1"></i> Create User
    </button>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading users...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadUsers">Retry</button>
    </div>
}
else
{
    <input class="form-control w-25 mb-3" placeholder="Search users..."
           value="@searchText"
           @oninput="OnSearchInput" />

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in FilteredUsers)
            {
                <tr>
                    <td>@user.FirstName @user.LastName</td>
                    <td>@user.Email</td>
                    <td><span class="badge bg-primary">@user.Role</span></td>
                    <td>@user.CreatedAt.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => OpenEditModal(user)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user.Id)">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!FilteredUsers.Any())
    {
        <p class="text-center text-muted py-3">No users found.</p>
    }

    <div class="mt-3 d-flex align-items-center gap-2">
        <button class="btn btn-secondary btn-sm" @onclick="PrevPage" disabled="@(_page == 1)">Prev</button>
        <span>Page @_page</span>
        <button class="btn btn-secondary btn-sm" @onclick="NextPage" disabled="@(!FilteredUsers.Any())">Next</button>
    </div>
}

@if (actionMessage != null)
{
    <div class="alert @(actionSuccess ? "alert-success" : "alert-danger") mt-3">@actionMessage</div>
}

@if (showCreateModal)
{
    <CreateUserModal Roles="roles" OnClose="CloseCreateModal" OnCreated="ReloadUsers" />
}

@if (showEditModal)
{
    <EditUserModal User="selectedUser" Roles="roles" OnClose="CloseEditModal" OnUpdated="ReloadUsers" />
}

@code {
    List<UserVM> users = new();
    List<string> roles = new();
    string searchText = "";
    int _page = 1;
    int pageSize = 10;
    bool showCreateModal = false;
    bool showEditModal = false;
    UserVM? selectedUser;
    bool isLoading = true;
    string? errorMessage;
    string? actionMessage;
    bool actionSuccess;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
        await LoadRoles();
    }

    async Task LoadUsers()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            users = await Http.GetFromJsonAsync<List<UserVM>>("api/admin/users") ?? new();
        }
        catch
        {
            errorMessage = "Failed to load users.";
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task LoadRoles()
    {
        try
        {
            roles = await Http.GetFromJsonAsync<List<string>>("api/admin/users/roles") ?? new();
        }
        catch { }
    }

    IEnumerable<UserVM> FilteredUsers =>
        users
        .Where(u =>
            string.IsNullOrWhiteSpace(searchText) ||
            (u.Email?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (u.FirstName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (u.LastName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .Skip((_page - 1) * pageSize)
        .Take(pageSize);

    void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        _page = 1;
        StateHasChanged();
    }

    void NextPage() => _page++;
    void PrevPage() { if (_page > 1) _page--; }

    void OpenCreateModal() => showCreateModal = true;
    void CloseCreateModal() => showCreateModal = false;

    void OpenEditModal(UserVM user) { selectedUser = user; showEditModal = true; }
    void CloseEditModal() => showEditModal = false;

    async Task ReloadUsers()
    {
        showCreateModal = false;
        showEditModal = false;
        await LoadUsers();
    }

    async Task DeleteUser(string id)
    {
        try
        {
            await Http.DeleteAsync($"api/admin/users/{id}");
            actionSuccess = true;
            actionMessage = "User deleted successfully.";
            await LoadUsers();
        }
        catch
        {
            actionSuccess = false;
            actionMessage = "Failed to delete user.";
        }
        StateHasChanged();
        await Task.Delay(3000);
        actionMessage = null;
        StateHasChanged();
    }
}
