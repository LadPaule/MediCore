@page "/doctors/create"
@attribute [Authorize(Roles = "Admin")]
@inject DoctorService DoctorService
@inject NavigationManager Navigation

<h3 class="mb-4">Register Doctor</h3>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <EditForm Model="doctor" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">First Name</label>
                    <InputText @bind-Value="doctor.FirstName" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Last Name</label>
                    <InputText @bind-Value="doctor.LastName" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText @bind-Value="doctor.Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Speciality</label>
                <InputText @bind-Value="doctor.Speciality" class="form-control" placeholder="e.g. Cardiology" />
            </div>

            <div class="mb-3">
                <label class="form-label">Initial Password</label>
                <InputText @bind-Value="doctor.Password" type="password" class="form-control" />
                <small class="text-muted">Must include an uppercase letter, a digit, and a special character (e.g. <code>Doctor@123</code>).</small>
            </div>

            @if (message != null)
            {
                <div class="alert @(isSuccess ? "alert-success" : "alert-danger") mb-3">@message</div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Register Doctor")
                </button>
                <a href="/doctors" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    CreateDoctorRequest doctor = new();
    bool isSaving;
    string? message;
    bool isSuccess;

    async Task Save()
    {
        isSaving = true;
        message = null;
        try
        {
            var (ok, error) = await DoctorService.CreateDoctorAsync(doctor);
            if (ok)
            {
                isSuccess = true;
                message = "Doctor registered.";
                await Task.Delay(800);
                Navigation.NavigateTo("/doctors");
            }
            else
            {
                isSuccess = false;
                message = error ?? "Failed to register doctor.";
            }
        }
        finally
        {
            isSaving = false;
        }
    }
}
